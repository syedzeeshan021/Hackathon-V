# Customer Success FTE - Git Ignore

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# ENVIRONMENT
# =============================================================================
.env
.env.local
.env.*.local
*.env

# =============================================================================
# SECRETS
# =============================================================================
*.pem
*.key
credentials.json
service_account.json
secrets/
!secrets/.gitkeep

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# DATABASE
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# KUBERNETES
# =============================================================================
# Keep templates, ignore generated files
*.generated.yaml
kubeconfig

# =============================================================================
# DOCKER
# =============================================================================
docker-compose.override.yml

# =============================================================================
# TESTING
# =============================================================================
test-results/
.junit.xml

# =============================================================================
# DOCUMENTATION
# =============================================================================
# Keep specs, ignore temporary notes
specs/drafts/
specs/*.tmp

# =============================================================================
# CONTEXT (Sample data - keep templates, ignore large files)
# =============================================================================
context/*.large.json
context/uploads/
