# Customer Success FTE - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# DATABASE (PostgreSQL + pgvector)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=customer_success
DB_USER=postgres
DB_PASSWORD=postgres
DB_MIN_CONNECTIONS=5
DB_MAX_CONNECTIONS=20

# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=customer_success

# =============================================================================
# GMAIL API (OAuth2)
# =============================================================================
GMAIL_ENABLED=true
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/webhooks/gmail/callback

# =============================================================================
# TWILIO (WhatsApp)
# =============================================================================
WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=AC-your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# WEB FORM
# =============================================================================
WEB_FORM_ENABLED=true

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_PORT=8000

# =============================================================================
# DOCKER COMPOSE
# =============================================================================
# These are used by docker-compose.yml
KAFKA_PORT=9092
KAFKA_UI_PORT=8090
